# 远程部署系统环境变量配置示例
# 请复制此文件为 .env 并填入实际值

# Codex API配置 (OpenAI Responses API)
CODEX_API_KEY=your_codex_api_key_here

# Claude API配置 (OpenAI-compatible relay)
CLAUDE_API_KEY=your_claude_api_key_here

# TOTP认证密钥 (Google Authenticator)
DEPLOY_TOTP_SECRET=your_totp_secret_here

# 服务器连接地址 (客户端配置)
SERVER_URL=ws://your_server_ip:5100/deploy/ws/client

# 使用说明:
# 1. 将此文件复制为 .env
# 2. 填入您的实际API密钥和配置
# 3. 确保 .env 文件不要提交到git仓库